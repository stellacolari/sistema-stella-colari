  @@index([origemId])
}

model LojaPagina {
  id                     String            @id @default(cuid())
  titulo                 String
  slug                   String            @unique
  tipo                   String            @default("GERAL")
  ativo                  Boolean           @default(true)
  criadoEm               DateTime          @default(now())
  atualizadoEm           DateTime          @updatedAt
  categoriaId            String?
  publicadoEm            DateTime?
  seoDescription         String?
  seoTitle               String?
  statusPublicacao       String            @default("PUBLICADA")
  usarComoTemplatePadrao Boolean           @default(false)
  categoria              CategoriaProduto? @relation("LojaPaginaCategoria", fields: [categoriaId], references: [id])
  blocos                 LojaPaginaBloco[]

  @@index([slug])
  @@index([tipo])
  @@index([ativo])
  @@index([categoriaId])
  @@index([statusPublicacao])
  @@index([usarComoTemplatePadrao])
}

model LojaPaginaBloco {
  id           String     @id @default(cuid())
  paginaId     String
  tipo         String
  titulo       String?
  ativo        Boolean    @default(true)
  ordem        Int        @default(0)
  configJson   Json
  criadoEm     DateTime   @default(now())
  atualizadoEm DateTime   @updatedAt
  pagina       LojaPagina @relation(fields: [paginaId], references: [id], onDelete: Cascade)

  @@index([paginaId])
  @@index([ordem])
  @@index([tipo])
  @@index([ativo])
}

model CategoriaProduto {
  id                         String                           @id @default(cuid())
  nome                       String
  slug                       String                           @unique
  descricao                  String?
  ativo                      Boolean                          @default(true)
  ordem                      Int                              @default(0)
  categoriaMaeId             String?
  criadoEm                   DateTime                         @default(now())
  atualizadoEm               DateTime                         @updatedAt
  exibirNoMenu               Boolean                          @default(true)
  imagemUrl                  String?
  ordemMenu                  Int                              @default(0)
  opcoesAdicionais           CategoriaOpcaoAdicional[]
  categoriaMae               CategoriaProduto?                @relation("CategoriaHierarquia", fields: [categoriaMaeId], references: [id])
  subcategorias              CategoriaProduto[]               @relation("CategoriaHierarquia")
  paginasBuilder             LojaPagina[]                     @relation("LojaPaginaCategoria")
  embalagensCompatibilidades EmbalagemModeloCompatibilidade[]
  produtos                   ProdutoCategoria[]

  @@index([categoriaMaeId])
  @@index([slug])
  @@index([ativo])
  @@index([ordem])
  @@index([exibirNoMenu])
  @@index([ordemMenu])
}

model ProdutoCategoria {
  id          String           @id @default(cuid())
  produtoId   String
  categoriaId String
  principal   Boolean          @default(false)
  criadoEm    DateTime         @default(now())
  categoria   CategoriaProduto @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  produto     Produto          @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([produtoId, categoriaId])
  @@index([produtoId])
  @@index([categoriaId])
  @@index([principal])
}

model ProdutoKitComponente {
