  alertasJson            Json?
  pesoTotalGramas        Float                      @default(0)
  alturaCm               Float?
  larguraCm              Float?
  comprimentoCm          Float?
  custoEmbalagens        Float                      @default(0)
  valorEmbalagensCliente Float                      @default(0)
