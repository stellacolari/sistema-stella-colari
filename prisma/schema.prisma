  itemAdicional        ItemAdicional?       @relation(fields: [itemAdicionalId], references: [id])
  embalagemModelo      EmbalagemModelo?     @relation(fields: [embalagemModeloId], references: [id])
  pedidoOnlineItem     PedidoOnlineItem?    @relation(fields: [pedidoOnlineItemId], references: [id])

  @@index([planoId])
  @@index([tipo])
  @@index([itemAdicionalId])
  @@index([embalagemModeloId])
  @@index([pedidoOnlineItemId])
}

model ClienteCashbackMovimentacao {
