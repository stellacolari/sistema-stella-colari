  atualizadoEm           DateTime                   @updatedAt
  pedidoOnline           PedidoOnline               @relation(fields: [pedidoOnlineId], references: [id], onDelete: Cascade)
  itens                  PedidoEmbalagemPlanoItem[]

  @@index([pedidoOnlineId])
  @@index([status])
}

model PedidoEmbalagemPlanoItem {
  id                   String               @id @default(cuid())
  planoId              String
  tipo                 String
  itemAdicionalId      String?
  embalagemModeloId    String?
  pedidoOnlineItemId   String?
