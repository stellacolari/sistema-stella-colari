generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id                             String                           @id @default(cuid())
  codigoInterno                  String                           @unique
  codigoFornecedor               String?
  nome                           String
  imagemUrl                      String?
  linkCompra                     String?
  custoBase                      Float
  margemAplicada                 Float
  precoVenda                     Float
  categoria                      String
  fornecedorPadrao               String
  ativo                          Boolean                          @default(true)
  observacoes                    String?
  criadoEm                       DateTime                         @default(now())
  atualizadoEm                   DateTime                         @updatedAt
  status                         String                           @default("ATIVO")
  statusAntesLixeira             String?
  descontoAtivo                  Boolean                          @default(false)
  precoPromocional               Float?
  imagemHoverUrl                 String?
  descricaoLoja                  String?
  tipoProduto                    String                           @default("UNITARIO")
  familiaId                      String?
  familiaMaterial                String?
  familiaCorJoia                 String?
  familiaImagemUrl               String?
  familiaOrdem                   Int                              @default(0)
  embalagemClasseId              String?
  embalagemUnidades              Float                            @default(1)
  embalagemCompartilhavel        Boolean                          @default(true)
  embalagemIndividualObrigatoria Boolean                          @default(false)
  embalagemModeloPreferencialId  String?
  permiteEmbalagemPresente       Boolean                          @default(true)
  embalagemPresentePadraoId      String?
  pesoGramas                     Float?
  alturaCm                       Float?
  larguraCm                      Float?
  comprimentoCm                  Float?
  compraItens                    CompraItem[]
  estoque                        EstoqueProduto[]
  embalagemClasse                EmbalagemClasse?                 @relation(fields: [embalagemClasseId], references: [id])
  embalagemModeloPreferencial    EmbalagemModelo?                 @relation("ProdutoEmbalagemPreferencial", fields: [embalagemModeloPreferencialId], references: [id])
  embalagemPresentePadrao        EmbalagemModelo?                 @relation("ProdutoEmbalagemPresentePadrao", fields: [embalagemPresentePadraoId], references: [id])
  familia                        ProdutoFamilia?                  @relation(fields: [familiaId], references: [id])
  embalagensCompatibilidades     EmbalagemModeloCompatibilidade[]
  canaisVenda                    ProdutoCanal[]
  categoriasProduto              ProdutoCategoria[]
  familiasVinculos               ProdutoFamiliaProduto[]
  imagens                        ProdutoImagem[]
  usadoEmKits                    ProdutoKitComponente[]           @relation("ComponenteProduto")
  componentesDoKit               ProdutoKitComponente[]           @relation("KitProduto")
  variacoes                      ProdutoVariacao[]
  vendasItens                    VendaItem[]

  @@index([familiaId])
  @@index([familiaMaterial])
  @@index([familiaCorJoia])
  @@index([embalagemClasseId])
  @@index([embalagemModeloPreferencialId])
  @@index([embalagemPresentePadraoId])
}

model ProdutoFamilia {
  id           String                  @id @default(cuid())
  nome         String
  slug         String                  @unique
  ativo        Boolean                 @default(true)
  ordem        Int                     @default(0)
  criadoEm     DateTime                @default(now())
  atualizadoEm DateTime                @updatedAt
  produtos     Produto[]
  campos       ProdutoFamiliaCampo[]
  vinculos     ProdutoFamiliaProduto[]

  @@index([ativo])
  @@index([ordem])
}

model ProdutoFamiliaCampo {
  id           String                       @id @default(cuid())
  familiaId    String
  nome         String
  slug         String
  ativo        Boolean                      @default(true)
  ordem        Int                          @default(0)
  criadoEm     DateTime                     @default(now())
  atualizadoEm DateTime                     @updatedAt
  familia      ProdutoFamilia               @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  valores      ProdutoFamiliaProdutoValor[]

  @@unique([familiaId, slug])
  @@index([familiaId])
  @@index([ativo])
  @@index([ordem])
}

model ProdutoFamiliaProduto {
  id           String                       @id @default(cuid())
  familiaId    String
  produtoId    String
  imagemUrl    String?
  ordem        Int                          @default(0)
  ativo        Boolean                      @default(true)
  criadoEm     DateTime                     @default(now())
  atualizadoEm DateTime                     @updatedAt
  familia      ProdutoFamilia               @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  produto      Produto                      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  valores      ProdutoFamiliaProdutoValor[]

  @@unique([familiaId, produtoId])
  @@index([familiaId])
  @@index([produtoId])
  @@index([ativo])
  @@index([ordem])
}

model ProdutoFamiliaProdutoValor {
  id               String                @id @default(cuid())
  familiaProdutoId String
  campoId          String
  valor            String
  criadoEm         DateTime              @default(now())
  atualizadoEm     DateTime              @updatedAt
  campo            ProdutoFamiliaCampo   @relation(fields: [campoId], references: [id], onDelete: Cascade)
  familiaProduto   ProdutoFamiliaProduto @relation(fields: [familiaProdutoId], references: [id], onDelete: Cascade)

  @@unique([familiaProdutoId, campoId])
  @@index([familiaProdutoId])
  @@index([campoId])
  @@index([valor])
}

model ProdutoImagem {
  id        String   @id @default(cuid())
  produtoId String
  imagemUrl String
  ordem     Int      @default(0)
  criadoEm  DateTime @default(now())
  produto   Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId])
  @@index([ordem])
}

model ProdutoVariacao {
  id           String                 @id @default(cuid())
  produtoId    String
  nome         String
  obrigatoria  Boolean                @default(true)
  ativo        Boolean                @default(true)
  ordem        Int                    @default(0)
  criadoEm     DateTime               @default(now())
  atualizadoEm DateTime               @updatedAt
  produto      Produto                @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  opcoes       ProdutoVariacaoOpcao[]

  @@index([produtoId])
  @@index([ativo])
  @@index([ordem])
}

model ProdutoVariacaoOpcao {
  id             String          @id @default(cuid())
  variacaoId     String
  nome           String
  imagemUrl      String?
  precoAdicional Float           @default(0)
  custoAdicional Float           @default(0)
  ativo          Boolean         @default(true)
  ordem          Int             @default(0)
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt
  variacao       ProdutoVariacao @relation(fields: [variacaoId], references: [id], onDelete: Cascade)

  @@index([variacaoId])
  @@index([ativo])
  @@index([ordem])
}

model ProdutoCanal {
  id                    String    @id @default(cuid())
  produtoId             String
  canal                 String
  skuExterno            String?
  produtoExternoId      String?
  variacaoExternaId     String?
  tituloExterno         String?
  precoCanal            Float?
  estoqueAnunciado      Int?
  sincronizarEstoque    Boolean   @default(true)
  sincronizarPreco      Boolean   @default(false)
  ativo                 Boolean   @default(true)
  ultimaSincronizacaoEm DateTime?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt
  produto               Produto   @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([canal, skuExterno])
  @@index([produtoId])
  @@index([canal])
  @@index([skuExterno])
  @@index([produtoExternoId])
  @@index([variacaoExternaId])
  @@index([ativo])
}

model ItemAdicional {
  id                            String                      @id @default(cuid())
  codigoInterno                 String                      @unique
  codigoFornecedor              String?
  nome                          String
  imagemUrl                     String?
  linkCompra                    String?
  custoBase                     Float
  fornecedorPadrao              String
  ativo                         Boolean                     @default(true)
  observacoes                   String?
  criadoEm                      DateTime                    @default(now())
  atualizadoEm                  DateTime                    @updatedAt
  status                        String                      @default("ATIVO")
  statusAntesLixeira            String?
  opcoesComoAdicionalConsumido  CategoriaOpcaoAdicional[]   @relation("CategoriaOpcaoItemAdicionalConsumido")
  opcoesComoPadraoSubstituido   CategoriaOpcaoAdicional[]   @relation("CategoriaOpcaoItemPadraoSubstituido")
  compraItens                   CompraItem[]
  estoque                       EstoqueAdicional?
  pedidosComoAdicionalConsumido PedidoOnlineItemAdicional[] @relation("PedidoItemAdicionalConsumido")
  pedidosComoPadraoSubstituido  PedidoOnlineItemAdicional[] @relation("PedidoItemPadraoSubstituido")
  embalagensComponentes         EmbalagemModeloComponente[]
  embalagensPlanoItens          PedidoEmbalagemPlanoItem[]
  regrasCategoria               RegraCategoria[]
}

model EmbalagemClasse {
  id               String                           @id @default(cuid())
  nome             String
  slug             String                           @unique
  descricao        String?
  ativo            Boolean                          @default(true)
  ordem            Int                              @default(0)
  criadoEm         DateTime                         @default(now())
  atualizadoEm     DateTime                         @updatedAt
  produtos         Produto[]
  compatibilidades EmbalagemModeloCompatibilidade[]

  @@index([ativo])
  @@index([ordem])
}

model EmbalagemModelo {
  id                       String                           @id @default(cuid())
  tipo                     String
  nomeInterno              String
  nomePublico              String?
  slug                     String                           @unique
  descricaoPublica         String?
  imagemUrl                String?
  ativo                    Boolean                          @default(true)
  exibirNaLoja             Boolean                          @default(false)
  prioridade               Int                              @default(0)
  precoCliente             Float                            @default(0)
  substituiEmbalagemPadrao Boolean                          @default(false)
  permiteMensagem          Boolean                          @default(false)
  mensagemLimiteCaracteres Int?
  mensagemPlaceholder      String?
  capacidadeUnidades       Float                            @default(1)
  capacidadeCaixasInternas Int?
  permiteMisturarClasses   Boolean                          @default(true)
  pesoGramas               Float                            @default(0)
  alturaCm                 Float?
  larguraCm                Float?
  comprimentoCm            Float?
  custoEstimadoManual      Float?
  criadoEm                 DateTime                         @default(now())
  atualizadoEm             DateTime                         @updatedAt
  componentes              EmbalagemModeloComponente[]
  compatibilidades         EmbalagemModeloCompatibilidade[]
  produtosPreferenciais    Produto[]                        @relation("ProdutoEmbalagemPreferencial")
  produtosPresentePadrao   Produto[]                        @relation("ProdutoEmbalagemPresentePadrao")
  pedidosPlanoItens        PedidoEmbalagemPlanoItem[]

  @@index([tipo])
  @@index([ativo])
  @@index([exibirNaLoja])
  @@index([prioridade])
}

model EmbalagemModeloComponente {
  id                String          @id @default(cuid())
  embalagemModeloId String
  itemAdicionalId   String
  quantidade        Float           @default(1)
  observacao        String?
  criadoEm          DateTime        @default(now())
  atualizadoEm      DateTime        @updatedAt
  embalagemModelo   EmbalagemModelo @relation(fields: [embalagemModeloId], references: [id], onDelete: Cascade)
  itemAdicional     ItemAdicional   @relation(fields: [itemAdicionalId], references: [id])

  @@unique([embalagemModeloId, itemAdicionalId])
  @@index([embalagemModeloId])
  @@index([itemAdicionalId])
}

model EmbalagemModeloCompatibilidade {
  id                    String            @id @default(cuid())
  embalagemModeloId     String
  classeId              String?
  categoriaId           String?
  produtoId             String?
  ativo                 Boolean           @default(true)
  prioridade            Int               @default(0)
  capacidadeMaximaItens Int               @default(1)
  criadoEm              DateTime          @default(now())
  atualizadoEm          DateTime          @updatedAt
  embalagemModelo       EmbalagemModelo   @relation(fields: [embalagemModeloId], references: [id], onDelete: Cascade)
  classe                EmbalagemClasse?  @relation(fields: [classeId], references: [id])
  categoria             CategoriaProduto? @relation(fields: [categoriaId], references: [id])
  produto               Produto?          @relation(fields: [produtoId], references: [id])

  @@index([embalagemModeloId])
  @@index([classeId])
  @@index([categoriaId])
  @@index([produtoId])
  @@index([ativo])
  @@index([prioridade])
}

model EmbalagemConfiguracao {
  id                        String   @id @default(cuid())
  chave                     String   @unique @default("PADRAO")
  estrategiaSelecao         String   @default("MENOR_CUSTO_TOTAL")
  permitirMultiplosVolumes  Boolean  @default(false)
  maxCaixasInternasPorEnvio Int?
  criadoEm                  DateTime @default(now())
  atualizadoEm              DateTime @updatedAt
}

model RegraCategoria {
  id                     String        @id @default(cuid())
  categoria              String
  quantidade             Int           @default(1)
  itemAdicionalId        String
  aplicarTodasCategorias Boolean       @default(false)
  categorias             Json?
  criadoEm               DateTime      @default(now())
  atualizadoEm           DateTime      @updatedAt
  itemAdicional          ItemAdicional @relation(fields: [itemAdicionalId], references: [id], onDelete: Cascade)
}

model Cliente {
  id                    String                        @id @default(cuid())
  codigo                String                        @unique
  nome                  String
  telefone              String                        @unique
  email                 String?                       @unique
  documento             String                        @unique
  cep                   String?
  rua                   String?
  numero                String?
  tipoCliente           String
  status                String                        @default("NOVO")
  observacoes           String?
  criadoEm              DateTime                      @default(now())
  atualizadoEm          DateTime                      @updatedAt
  statusAntesLixeira    String?
  cashbackSaldo         Float                         @default(0)
  origemCadastro        String?
  senhaHash             String?
  bairro                String?
  cidade                String?
  complemento           String?
  estado                String?
  cashbackMovimentacoes ClienteCashbackMovimentacao[]
  pedidosOnline         PedidoOnline[]
  vendas                Venda[]
}

model Compra {
  id                     String       @id @default(cuid())
  codigo                 String       @unique
  fornecedor             String
  descontoPercentual     Float        @default(0)
  frete                  Float        @default(0)
  valorTotalBruto        Float        @default(0)
  valorTotalFinal        Float        @default(0)
  observacoes            String?
  criadoEm               DateTime     @default(now())
  atualizadoEm           DateTime     @updatedAt
  canceladoEm            DateTime?
  cancelamentoMotivo     String?
  cancelamentoObservacao String?
  status                 String       @default("ATIVA")
  statusAntesLixeira     String?
  itens                  CompraItem[]
}

model CompraItem {
  id                 String         @id @default(cuid())
  compraId           String
  tipoItem           String
  codigoDigitado     String
  descricao          String
  quantidade         Int
  valorUnitarioBase  Float
  valorUnitarioFinal Float
  valorTotalBase     Float
  valorTotalFinal    Float
  parcelaFrete       Float          @default(0)
  valorTotalComFrete Float          @default(0)
  produtoId          String?
  itemAdicionalId    String?
  criadoEm           DateTime       @default(now())
  atualizadoEm       DateTime       @updatedAt
  tamanhoAnel        String?
  compra             Compra         @relation(fields: [compraId], references: [id], onDelete: Cascade)
  itemAdicional      ItemAdicional? @relation(fields: [itemAdicionalId], references: [id])
  produto            Produto?       @relation(fields: [produtoId], references: [id])

  @@index([compraId])
  @@index([produtoId])
  @@index([itemAdicionalId])
}

model EstoqueProduto {
  id              String   @id @default(cuid())
  produtoId       String
  quantidadeAtual Int      @default(0)
  valorAcumulado  Float    @default(0)
  custoMedio      Float    @default(0)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  tamanhoAnel     String   @default("UNICO")
  produto         Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([produtoId, tamanhoAnel])
  @@index([produtoId])
  @@index([tamanhoAnel])
}

model EstoqueAdicional {
  id              String        @id @default(cuid())
  itemAdicionalId String        @unique
  quantidadeAtual Int           @default(0)
  valorAcumulado  Float         @default(0)
  custoMedio      Float         @default(0)
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt
  itemAdicional   ItemAdicional @relation(fields: [itemAdicionalId], references: [id], onDelete: Cascade)
}

model Movimentacao {
  id                    String                  @id @default(cuid())
  codigoMovimentacao    String                  @unique
  tipoMovimentacao      String
  origemTipo            String
  origemId              String
  codigoItem            String
  itemTipo              String
  quantidade            Int
  custo                 Float                   @default(0)
  faturamento           Float                   @default(0)
  documentoCliente      String?
  status                String
  relacionadoA          String?
  gastoProdutoPrincipal Float                   @default(0)
  gastoAdd1             Float                   @default(0)
  gastoAdd2             Float                   @default(0)
  gastoAdd3             Float                   @default(0)
  criadoEm              DateTime                @default(now())
  atualizadoEm          DateTime                @updatedAt
  tamanhoAnel           String?
  adicionaisConsumidos  MovimentacaoAdicional[]
}

model Venda {
  id                     String      @id @default(cuid())
  codigo                 String      @unique
  clienteId              String
  meioVenda              String
  descontoPercentual     Float       @default(0)
  valorTotal             Float       @default(0)
  gastoTotal             Float       @default(0)
  lucroTotal             Float       @default(0)
  observacoes            String?
  criadoEm               DateTime    @default(now())
  atualizadoEm           DateTime    @updatedAt
  status                 String      @default("VENDA_FINALIZADA")
  canceladoEm            DateTime?
  cancelamentoMotivo     String?
  cancelamentoObservacao String?
  statusAntesLixeira     String?
  cliente                Cliente     @relation(fields: [clienteId], references: [id])
  itens                  VendaItem[]
}

model VendaItem {
  id                 String   @id @default(cuid())
  vendaId            String
  produtoId          String
  codigoDigitado     String
  descricao          String
  quantidade         Int
  valorUnitarioBase  Float
  valorUnitarioFinal Float
  valorTotal         Float
  gastoProduto       Float    @default(0)
  gastoAdicionais    Float    @default(0)
  lucroTotal         Float    @default(0)
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
  tamanhoAnel        String?
  produto            Produto  @relation(fields: [produtoId], references: [id])
  venda              Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
}

model MovimentacaoAdicional {
  id             String       @id @default(cuid())
  movimentacaoId String
  codigoItem     String
  nomeItem       String
  quantidade     Float
  custoUnitario  Float
  custoTotal     Float
  criadoEm       DateTime     @default(now())
  movimentacao   Movimentacao @relation(fields: [movimentacaoId], references: [id], onDelete: Cascade)

  @@index([movimentacaoId])
  @@index([codigoItem])
}

model BannerLoja {
  id              String   @id @default(cuid())
  titulo          String?
  subtitulo       String?
  imagemUrl       String
  linkUrl         String?
  ordem           Int      @default(0)
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  imagemMobileUrl String?
}

model MenuLoja {
  id                     String    @id @default(cuid())
  nome                   String
  slug                   String    @unique
  tipo                   String
  linkUrl                String?
  categoria              String?
  ativo                  Boolean   @default(true)
  ordem                  Int       @default(0)
  dataInicio             DateTime?
  dataFim                DateTime?
  criadoEm               DateTime  @default(now())
  atualizadoEm           DateTime  @updatedAt
  categoriasSelecionadas String?
  corDestaque            String?
  destaque               Boolean   @default(false)
  paginaEspecial         String?
}

model LojaCategoriaHome {
  id           String   @id @default(cuid())
  titulo       String
  categoria    String
  imagemUrl    String
  ordem        Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([categoria])
  @@index([ordem])
}

model LojaSecaoHome {
  id           String   @id @default(cuid())
  titulo       String
  categorias   String
  ordem        Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([ordem])
}

model LojaBlocoHome {
  id           String   @id @default(cuid())
  titulo       String
  texto        String
  imagemUrl    String?
  textoBotao   String?
  linkBotao    String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model LojaTextoInstitucional {
  id           String   @id @default(cuid())
  chave        String   @unique
  titulo       String
  conteudo     String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model PedidoOnline {
  id                         String                      @id @default(cuid())
  codigo                     String                      @unique
  clienteId                  String?
  clienteCriadoCheckout      Boolean                     @default(false)
  nomeCliente                String
  telefoneCliente            String
  emailCliente               String?
  documento                  String?
  cep                        String?
  rua                        String?
  numero                     String?
  complemento                String?
  bairro                     String?
  cidade                     String?
  estado                     String?
  subtotal                   Float                       @default(0)
  frete                      Float                       @default(0)
  total                      Float                       @default(0)
  cashbackBaseValor          Float                       @default(0)
  cashbackPrevistoValor      Float                       @default(0)
  cashbackCreditadoValor     Float                       @default(0)
  cashbackCreditadoEm        DateTime?
  cashbackStatus             String                      @default("NAO_APLICAVEL")
  status                     String                      @default("AGUARDANDO_PAGAMENTO")
  observacoes                String?
  criadoEm                   DateTime                    @default(now())
  atualizadoEm               DateTime                    @updatedAt
  gatewayPagamento           String?
  gatewayPagamentoId         String?
  gatewayPedidoId            String?
  metodoPagamento            String?
  pagamentoObservacao        String?
  pagoEm                     DateTime?
  statusPagamento            String                      @default("AGUARDANDO_PAGAMENTO")
  valorPago                  Float                       @default(0)
  codigoPedidoExterno        String?
  dadosOriginaisJson         Json?
  origemCanal                String                      @default("LOJA_STELLA")
  statusExterno              String?
  substatusExterno           String?
  cashbackBloqueadoMotivo    String?
  cashbackPercentualAplicado Float                       @default(0)
  cupomCodigo                String?
  cupomDescontoValor         Float                       @default(0)
  cupomId                    String?
  cashbackUsadoValor         Float                       @default(0)
  envio                      PedidoEnvio?
  cliente                    Cliente?                    @relation(fields: [clienteId], references: [id])
  cupom                      CupomLoja?                  @relation(fields: [cupomId], references: [id])
  embalagemPlano             PedidoEmbalagemPlano?
  itens                      PedidoOnlineItem[]
  adicionais                 PedidoOnlineItemAdicional[]
  statusHistorico            PedidoStatusHistorico[]

  @@index([clienteId])
  @@index([codigo])
  @@index([status])
  @@index([cashbackStatus])
  @@index([statusPagamento])
  @@index([gatewayPedidoId])
  @@index([gatewayPagamentoId])
  @@index([pagoEm])
  @@index([origemCanal])
  @@index([codigoPedidoExterno])
  @@index([origemCanal, codigoPedidoExterno])
  @@index([cupomId])
  @@index([cupomCodigo])
}

model PedidoOnlineItem {
  id                  String                      @id @default(cuid())
  pedidoOnlineId      String
  produtoId           String?
  codigoInterno       String
  nomeProduto         String
  imagemUrl           String?
  categoria           String
  tamanhoAnel         String?
  quantidade          Int
  precoUnitario       Float
  precoOriginal       Float?
  descontoPercentual  Float?
  geraCashback        Boolean                     @default(false)
  cashbackBaseValor   Float                       @default(0)
  total               Float
  criadoEm            DateTime                    @default(now())
  pedidoOnline        PedidoOnline                @relation(fields: [pedidoOnlineId], references: [id], onDelete: Cascade)
  embalagemPlanoItens PedidoEmbalagemPlanoItem[]
  adicionais          PedidoOnlineItemAdicional[]

  @@index([pedidoOnlineId])
  @@index([produtoId])
  @@index([codigoInterno])
}

model PedidoEmbalagemPlano {
  id                     String                     @id @default(cuid())
  pedidoOnlineId         String                     @unique
  status                 String                     @default("CALCULADO")
